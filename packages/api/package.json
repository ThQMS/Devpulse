{
  "name": "api",
  "version": "0.1.0",
  "description": "DevPulse REST API, WebSocket gateway and health-check worker.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThQMS/Devpulse.git",
    "directory": "packages/api"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-migrations.mjs",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\"",
    "migrate": "tsx src/infrastructure/database/migrate.ts",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@devpulse/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^10.0.1",
    "axios": "^1.7.2",
    "bullmq": "^5.7.0",
    "fastify": "^4.27.0",
    "ioredis": "^5.4.1",
    "neverthrow": "^6.2.1",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
